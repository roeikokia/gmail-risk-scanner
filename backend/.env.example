# ==========================================================
# Gmail Risk Scanner — Configuration template
# Copy this file to `.env` and fill in your own values.
# Never commit a real `.env` to git.
# ==========================================================

APP_ENV=development

# Risk scoring thresholds (composite, 0-100 scale)
ALERT_THRESHOLD=35
HIGH_RISK_THRESHOLD=70

# --- Threat Intelligence ---
# Get a free key at https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=
# Get a free key at https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=

# --- AI Layer ---
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# --- Additional URL reputation sources (v2) ---
# Google Safe Browsing v4 Lookup API (free, 10,000 req/day).
GOOGLE_SAFE_BROWSING_API_KEY=
# URLhaus by abuse.ch — get a free Auth-Key at https://auth.abuse.ch/
URLHAUS_API_KEY=

# --- Quarantine policy ---
SPAM_QUARANTINE_SCORE=70
VT_PROVEN_MALICIOUS_ENGINES=5
ABUSEIPDB_PROVEN_MALICIOUS_CONFIDENCE=75

# --- SOC alert recipient ---
SOC_ALERT_EMAIL=
